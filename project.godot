; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Domucki"
run/main_scene="res://levels/test/test_arena.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://src/systems/game_manager.gd"
EventBus="*res://src/systems/event_bus.gd"
SaveManager="*res://src/systems/save_manager.gd"
AudioManager="*res://src/systems/audio_manager.gd"
SceneManager="*res://src/systems/scene_manager.gd"
HUD="*res://src/ui/hud/hud.tscn"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

