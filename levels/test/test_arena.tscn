[sub_resource type="Shader" id="Shader_grid"]
code = "shader_type spatial;

uniform vec4 line_color : source_color = vec4(0.3, 0.3, 0.3, 1.0);
uniform vec4 bg_color : source_color = vec4(0.45, 0.45, 0.45, 1.0);
uniform float grid_scale = 50.0;
uniform float line_width = 0.03;

void fragment() {
	vec2 grid_uv = fract(UV * grid_scale);
	float line = step(grid_uv.x, line_width) + step(1.0 - line_width, grid_uv.x)
	           + step(grid_uv.y, line_width) + step(1.0 - line_width, grid_uv.y);
	line = clamp(line, 0.0, 1.0);
	ALBEDO = mix(bg_color.rgb, line_color.rgb, line);
}
"

